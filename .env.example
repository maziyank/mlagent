# OpenRouter API key (required for --mode agent)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model spec: openrouter:<openrouter-model-id>
# https://openrouter.ai/models
MLAGENT_MODEL=openrouter:openai/gpt-4o-mini

# template | agent
MLAGENT_EXECUTION_MODE=template
MLAGENT_LLM_LOG_ENABLED=true

# LangSmith (agent observability; optional)
# https://smith.langchain.com/
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mlagent

# Continuous optimization (modeling + evaluation stages)
MLAGENT_OPTIMIZATION_ENABLED=true
MLAGENT_OPTIMIZATION_PATIENCE=2
MLAGENT_OPTIMIZATION_MIN_IMPROVEMENT=0.001
MLAGENT_OPTIMIZATION_STAGES=modeling,evaluation
